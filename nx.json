{
  "installation": {
    "version": "22.5.3"
  },
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/**/*"],
    "python": ["{projectRoot}/**/*.py", "{projectRoot}/requirements.txt"]
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "outputs": ["{projectRoot}/dist"]
    },
    "test": {
      "cache": true,
      "outputs": ["{projectRoot}/coverage"]
    },
    "lint": {
      "cache": true
    },
    "typecheck": {
      "cache": true
    }
  }
}