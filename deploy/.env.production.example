# Copy this to /opt/tms/.env.production on the server.
# DO NOT commit the real .env.production to git.

# ---- Database ----
POSTGRES_USER=tms
POSTGRES_PASSWORD=REPLACE_WITH_OPENSSL_RAND_BASE64_32
POSTGRES_DB=tms_prod

# ---- Connection strings (consumed by tms_api container) ----
# IMPORTANT: the password here must match POSTGRES_PASSWORD above.
DATABASE_URL=postgresql://tms:REPLACE_WITH_OPENSSL_RAND_BASE64_32@tms_postgres:5432/tms_prod
REDIS_URL=redis://tms_redis:6379

# ---- JWT ----
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- API ----
API_PORT=3001
NODE_ENV=production

# ---- Optimizer ----
OPTIMIZER_URL=http://tms_optimizer:8000

# ---- External services ----
NOMINATIM_URL=https://nominatim.openstreetmap.org

# ---- Image references (set per-deploy by GitHub Actions; defaults are fine for manual ops) ----
API_IMAGE=ghcr.io/NrohoOrg/tms-api:latest
OPTIMIZER_IMAGE=ghcr.io/NrohoOrg/tms-optimizer:latest
WEB_IMAGE=ghcr.io/NrohoOrg/tms-web:latest
