# Frontend environment variables

# Public URL of the backend API. NEXT_PUBLIC_* vars are baked in at BUILD
# TIME — set this on the frontend host (Vercel/etc.) and redeploy after
# any change. Local dev defaults to http://localhost:3001/api when unset.
# Production example:
#   NEXT_PUBLIC_API_BASE_URL=https://api.tms.nroho.dz/api
NEXT_PUBLIC_API_BASE_URL=https://api.tms.nroho.dz/api

# Backend environment variables
DATABASE_URL=postgresql://dispatch:dispatch@postgres:5432/dispatch_dev
REDIS_URL=redis://redis:6379
JWT_SECRET=changeme_jwt_secret_dev
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
API_PORT=3001
# Comma-separated list of allowed browser origins for CORS. The deployed
# frontend's full origin (scheme + host, no path) MUST be in here.
CORS_ALLOWED_ORIGINS=https://tms.nroho.dz,https://www.tms.nroho.dz,http://localhost:3000
OPTIMIZER_URL=http://optimizer:8000
# Google Places API key (Autocomplete + Details). Required for the geocoder.
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_AUTOCOMPLETE_BASE_URL=https://maps.googleapis.com/maps/api/place/autocomplete/json
GOOGLE_MAPS_DETAILS_BASE_URL=https://maps.googleapis.com/maps/api/place/details/json
# Distance Matrix endpoint used by the OR routing layer to fetch
# road-distance and traffic-aware travel time. Same key as Places.
# REQUIRES the "Distance Matrix API" SKU enabled in Google Cloud
# Console for GOOGLE_MAPS_API_KEY. When the key is unset the routing
# layer falls back to in-memory haversine.
GOOGLE_DISTANCE_MATRIX_BASE_URL=https://maps.googleapis.com/maps/api/distancematrix/json

# Icosnet SMS provider (driver notifications on plan publish)
ICOSNET_SMS_BASE_URL=https://smsapi.icosnet.com:8443/bulksms/bulksms
ICOSNET_SMS_USERNAME=
ICOSNET_SMS_PASSWORD=
ICOSNET_SMS_SOURCE=Nroho
ICOSNET_SMS_TYPE=0
ICOSNET_SMS_DLR=1
# Test override: when set, every driver SMS is routed to this number instead of the
# real driver phone. Leave empty in production.
# SMS_TEST_OVERRIDE_NUMBER=0556495709

NODE_ENV=development
