generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  phone         String?
  lastLogin     DateTime?
  passwordHash  String
  role          Role     @default(DISPATCHER)
  createdAt     DateTime @default(now())
  refreshTokens RefreshToken[]
  plans         Plan[]
  optimizationJobs OptimizationJob[]
  tasksCreated  Task[]   @relation("TaskCreatedBy")
  tasksDecided  Task[]   @relation("TaskDecidedBy")
}

enum Role {
  ADMIN
  DISPATCHER
  CADRE
}

enum TaskApprovalStatus {
  pending_approval
  approved
  rejected
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}

model Driver {
  id            String   @id @default(uuid())
  name          String
  phone         String
  shiftStart    String
  shiftEnd      String
  depotLat      Float
  depotLng      Float
  capacityUnits Int?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  availability  Availability[]
  routes        Route[]
}

model Availability {
  id                 String   @id @default(uuid())
  driverId           String
  date               DateTime @db.Date
  available          Boolean  @default(true)
  shiftStartOverride String?
  shiftEndOverride   String?
  driver             Driver   @relation(fields: [driverId], references: [id])
  @@unique([driverId, date])
}

enum Priority {
  normal
  urgent
}

enum TaskStatus {
  pending
  assigned
  cancelled
}

model Task {
  id                    String     @id @default(uuid())
  title                 String
  pickupAddress         String
  pickupLat             Float
  pickupLng             Float
  pickupWindowStart     DateTime
  pickupWindowEnd       DateTime
  pickupServiceMinutes  Int        @default(0)
  dropoffAddress        String
  dropoffLat            Float
  dropoffLng            Float
  priority              Priority   @default(normal)
  status                TaskStatus @default(pending)
  notes                 String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  approvalStatus        TaskApprovalStatus @default(approved)
  createdById           String?
  createdBy             User?      @relation("TaskCreatedBy", fields: [createdById], references: [id])
  decidedAt             DateTime?
  decidedById           String?
  decidedBy             User?      @relation("TaskDecidedBy", fields: [decidedById], references: [id])
  stops                 Stop[]
}

enum PlanStatus {
  draft
  published
}

model Plan {
  id              String     @id @default(uuid())
  date            DateTime   @db.Date
  status          PlanStatus @default(draft)
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  createdById     String
  notes           String?
  lastEditedAt    DateTime?
  lastEditedById  String?
  createdBy       User       @relation(fields: [createdById], references: [id])
  routes          Route[]
  jobs            OptimizationJob[]
}

model Route {
  id              String  @id @default(uuid())
  planId          String
  driverId        String
  totalDistanceM  Int     @default(0)
  totalTimeS      Int     @default(0)
  plan            Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  driver          Driver  @relation(fields: [driverId], references: [id])
  stops           Stop[]

  @@unique([planId, driverId])
}

enum StopType {
  pickup
  dropoff
}

enum StopStatus {
  pending
  arrived
  done
  skipped
}

model Stop {
  id                String      @id @default(uuid())
  routeId           String
  taskId            String
  sequence          Int
  type              StopType
  etaS              Int
  departureS        Int
  actualArrivalS    Int?
  completedAt       DateTime?
  notes             String?
  status            StopStatus  @default(pending)
  locked            Boolean     @default(false)
  manuallyAssigned  Boolean     @default(false)
  route             Route       @relation(fields: [routeId], references: [id], onDelete: Cascade)
  task              Task        @relation(fields: [taskId], references: [id])
  stopEvents        StopEvent[]
}

model StopEvent {
  id        String     @id @default(uuid())
  stopId    String
  status    StopStatus
  timestamp DateTime   @default(now())
  notes     String?
  createdBy String
  stop      Stop       @relation(fields: [stopId], references: [id])
}

enum JobStatus {
  queued
  running
  completed
  failed
}

model OptimizationJob {
  id              String    @id @default(uuid())
  createdById     String
  status          JobStatus @default(queued)
  progressPercent Int       @default(0)
  startedAt       DateTime?
  finishedAt      DateTime?
  planId          String?
  error           String?
  requestSnapshot Json?
  resultSnapshot  Json?
  createdAt       DateTime  @default(now())
  createdBy       User      @relation(fields: [createdById], references: [id])
  plan            Plan?     @relation(fields: [planId], references: [id])
}

model Config {
  id                          Int      @id @default(1)
  maxSolveSeconds             Int      @default(30)
  speedKmh                    Float    @default(40)
  objectiveWeights            Json    @default("{\"urgent\":1000,\"high\":500,\"normal\":100,\"low\":10}")
  pickupServiceMinutesDefault Int      @default(20)
  dropoffServiceMinutesDefault Int     @default(5)
  // Carpool / shared-trip lever. When the driver visits the same
  // coordinates back-to-back (e.g. three passengers boarding at one
  // address), every stop in the cluster except the last is charged this
  // marginal service time instead of the full pickup/dropoff service.
  // The full service is paid once when the driver actually leaves the
  // cluster. Default 60 s ≈ "name confirm + door close per extra rider".
  colocatedMarginalServiceSeconds Int  @default(60)
  dropoffWithinHours          Int      @default(2)
  loadBalancingKmPerTask      Int      @default(15)
  // Impact / KPI constants and OR objective coefficients. Defaults reflect
  // a Hyundai Accent fleet on essence sans plomb at 47 DZD/L.
  // dieselPricePerLiterDZD field name is preserved for back-compat with the
  // impact endpoint; it now holds the petrol price in DZD/L.
  co2GramsPerKm               Int      @default(140)
  fuelLPer100Km               Float    @default(6)
  dieselPricePerLiterDZD      Int      @default(47)
  // Hourly time-cost in DZD used in the OR objective. Calibrated so that
  // 1 km of fuel and 1 hour of driving have equivalent weight at typical
  // Algiers urban speed (~25 km/h). Lower = optimizer favours shorter
  // distance; higher = favours shorter time.
  timeCostDzdPerHour          Float    @default(70)
  // Penalty (DZD) for leaving a task unassigned. Sized to dwarf any
  // plausible arc cost so every feasible task is assigned; the
  // unassigned[] response only carries genuinely infeasible tasks
  // (TIME_WINDOW_INFEASIBLE, CAPACITY_EXCEEDED, NO_DRIVER_AVAILABLE).
  // Urgent > normal preserves priority when capacity is the bottleneck.
  unassignedPenaltyNormalDzd  Int      @default(100000)
  unassignedPenaltyUrgentDzd  Int      @default(1000000)
  // Cap on outbound SMS per calendar day (UTC). Once reached, sms.service
  // refuses additional sends and returns success=false. Admin-tunable.
  smsDailyLimit               Int      @default(50)
  updatedAt                   DateTime @updatedAt
}

/// Persistent cache of road-routing matrix entries (distance + duration)
/// between two coordinates. Filled on cache miss by GoogleDistanceMatrixProvider
/// and never expires — Algiers road geometry changes rarely, and Google's
/// own freshness is what matters most. Coordinates are stored rounded to
/// 5 decimals (~1 m) so near-duplicate addresses share a row.
model RouteMatrixCache {
  id         String   @id @default(uuid())
  fromLat    Float
  fromLng    Float
  toLat      Float
  toLng      Float
  distanceM  Int
  durationS  Int
  computedAt DateTime @default(now())

  @@unique([fromLat, fromLng, toLat, toLng], name: "route_matrix_pair")
  @@index([fromLat, fromLng])
}

/// One row per outbound SMS attempt that actually hit the provider.
/// Used to enforce the per-day quota and for audit.
model SmsLog {
  id               String   @id @default(uuid())
  destination      String
  success          Boolean
  providerCode     String?
  providerResponse String?
  sentAt           DateTime @default(now())

  @@index([sentAt])
}

model GeocodeCache {
  normalizedQuery String   @id
  results         Json
  expiresAt       DateTime
}
